rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'jitendraeditiz@gmail.com' && 
        request.auth.token.email_verified == true
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Product Validation
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'originalPrice', 'finalPrice', 'category', 'imageUrl', 'purchaseLink']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.originalPrice is number && data.originalPrice > 0 &&
             data.finalPrice is number && data.finalPrice > 0 && data.finalPrice <= data.originalPrice &&
             data.category is string && data.category.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 2048 &&
             data.purchaseLink is string && data.purchaseLink.size() <= 2048 &&
             (!('subCategory' in data) || (data.subCategory is string && data.subCategory.size() <= 100)) &&
             (!('brand' in data) || (data.brand is string && data.brand.size() <= 100)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 20)) &&
             (!('availability' in data) || (data.availability is bool));
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; // Public read access
      
      allow create: if isAdmin() && 
                      isValidProduct(incoming()) && 
                      incoming().createdAt == request.time;
      
      allow update: if isAdmin() && 
                      isValidProduct(incoming()) && 
                      incoming().updatedAt == request.time &&
                      incoming().createdAt == existing().createdAt;
      
      allow delete: if isAdmin();
    }
  }
}
